# AgentNode Backend — Environment Variables
# Copy this file to .env and fill in the values.

# Database (PostgreSQL with asyncpg)
DATABASE_URL=postgresql+asyncpg://agentnode:agentnode@localhost:5432/agentnode

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=your-meilisearch-master-key

# S3 / MinIO (artifact storage)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=https://s3.yourdomain.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=agentnode-artifacts
S3_REGION=auto

# JWT Authentication
JWT_SECRET=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# API Key prefix
API_KEY_PREFIX=ank_

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Email / SMTP (leave empty to disable — emails logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@agentnode.net
EMAIL_FROM_NAME=AgentNode
FRONTEND_URL=https://agentnode.net

# Environment: development | production
ENVIRONMENT=development
