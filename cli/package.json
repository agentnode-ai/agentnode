{
  "name": "agentnode-cli",
  "version": "0.1.0",
  "description": "CLI for AgentNode — discover, resolve, and install AI agent capabilities.",
  "type": "module",
  "bin": {
    "agentnode": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "capabilities",
    "package-manager",
    "cli",
    "agentnode",
    "mcp",
    "langchain"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agentnode-ai/agentnode"
  },
  "homepage": "https://agentnode.net",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
